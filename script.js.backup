/**
 * 判断牌面类型
 */
function getReadingType(cards) {
    const positiveCards = ['The Sun', 'The Star', 'The World', 'The Magician', 'The Empress', 'The Fool'];
    const challengingCards = ['The Moon', 'The Tower', 'The Devil', 'Death', 'The Hanged Man'];
    const transformativeCards = ['Wheel of Fortune', 'Death', 'Judgement', 'The Tower'];
    
    let positiveCount = 0;
    let challengingCount = 0;
    let transformativeCount = 0;
    
    cards.forEach(card => {
        if (positiveCards.includes(card.name)) positiveCount++;
        if (challengingCards.includes(card.name)) challengingCount++;
        if (transformativeCards.includes(card.name)) transformativeCount++;
    });
    
    if (transformativeCount >= 1) return 'transformative';
    if (challengingCount >= 2) return 'challenging';
    if (positiveCount >= 2) return 'positive';
    return 'mixed';
}

/**
 * 页面切换
 */
function goToPage(pageId) {
    document.querySelectorAll('.page').forEach(page => {
        page.classList.remove('active');
    });
    document.getElementById(pageId).classList.add('active');
    
    if (pageId === 'page-draw') {
        initDrawPage();
    } else if (pageId === 'page-interpret') {
        generateInterpretation();
    } else if (pageId === 'page-relationship-interpret') {
        generateRelationshipInterpretation();
    } else if (pageId === 'page-wisdom') {
        generateWisdom();
    } else if (pageId === 'page-share') {
        prepareShareCard();
    }
}

/**
 * 选择占卜模式
 */
function selectMode(mode) {
    state.mode = mode;
    if (mode === 'general') {
        goToPage('page-input');
    } else {
        goToPage('page-relationship-input');
    }
}

/**
 * 填充问题示例
 */
function fillQuestion(question) {
    document.getElementById('question-input').value = question;
}

/**
 * 填充名字示例
 */
function fillPersonName(name) {
    document.getElementById('person-name-input').value = name;
}

/**
 * 提交问题
 */
function submitQuestion() {
    const question = document.getElementById('question-input').value.trim();
    if (!question) {
        alert('请先输入你的问题');
        return;
    }
    state.question = question;
    goToPage('page-draw');
}

/**
 * 提交关系占卜
 */
function submitRelationship() {
    const name = document.getElementById('person-name-input').value.trim();
    if (!name) {
        alert('请输入一个人的名字');
        return;
    }
    state.personName = name;
    goToPage('page-draw');
}

/**
 * 初始化抽牌页面
 */
function initDrawPage() {
    state.revealedCards = 0;
    state.cards = [];
    
    // 随机抽取3张不重复的牌
    const shuffled = [...tarotCards].sort(() => Math.random() - 0.5);
    state.cards = shuffled.slice(0, 3);
    
    document.querySelectorAll('.card').forEach(card => {
        card.classList.remove('revealed');
    });
    
    state.cards.forEach((card, index) => {
        const cardEl = document.getElementById(`card-${index + 1}`);
        const cardBack = cardEl.querySelector('.card-back');
        cardBack.innerHTML = `
            <div class="card-content">
                <div class="card-number">${card.nameCN}</div>
                <div class="card-name">${card.name}</div>
                <div class="card-meaning">${card.keywords[0]}</div>
            </div>
        `;
    });
    
    document.getElementById('btn-interpret').style.display = 'none';
}

/**
 * 翻开卡牌
 */
function revealCard(cardIndex) {
    const card = document.getElementById(`card-${cardIndex}`);
    if (card.classList.contains('revealed')) return;
    
    card.classList.add('revealed');
    state.revealedCards++;
    
    if (state.revealedCards === 3) {
        setTimeout(() => {
            // 根据模式显示不同的按钮
            if (state.mode === 'relationship') {
                document.getElementById('btn-interpret').textContent = '查看宇宙低语';
                document.getElementById('btn-interpret').onclick = () => goToPage('page-relationship-interpret');
            } else {
                document.getElementById('btn-interpret').textContent = '查看宇宙解读';
                document.getElementById('btn-interpret').onclick = () => goToPage('page-interpret');
            }
            document.getElementById('btn-interpret').style.display = 'inline-block';
        }, 700);
    }
}

/**
 * 生成宇宙解读 - 智能组合算法
 */
function generateInterpretation() {
    // 生成随机编号 (1000-9999)
    const answerId = Math.floor(1000 + Math.random() * 9000);
    document.querySelector('#answer-id span').textContent = answerId;
    
    document.getElementById('display-question').textContent = state.question;
    
    state.cards.forEach((card, index) => {
        const miniCard = document.getElementById(`mini-card-${index + 1}`);
        const labels = ['现状', '隐匿', '未来'];
        miniCard.innerHTML = `
            <div style="font-size:0.6rem;color:rgba(157,123,255,0.8);margin-bottom:2px;">${labels[index]}</div>
            <div style="font-size:0.7rem;font-weight:bold;">${card.nameCN}</div>
            <div style="font-size:0.5rem;margin-top:2px;opacity:0.7;">${card.keywords[0]}</div>
        `;
    });
    
    document.getElementById('interpret-loading').style.display = 'block';
    document.getElementById('interpret-content').style.display = 'none';
    document.getElementById('btn-wisdom').style.display = 'none';
    
    setTimeout(() => {
        const interpretation = generateSmartInterpretation();
        
        // 5%概率触发宇宙特别讯息（隐藏彩蛋）
        let specialMessage = '';
        if (Math.random() < 0.05) {
            const randomMessage = specialMessages[Math.floor(Math.random() * specialMessages.length)];
            specialMessage = '\n\n✦ 宇宙特别讯息：' + randomMessage;
        }
        
        state.interpretation = interpretation + specialMessage;
        
        document.getElementById('interpret-text').textContent = state.interpretation;
        document.getElementById('interpret-loading').style.display = 'none';
        document.getElementById('interpret-content').style.display = 'block';
        document.getElementById('btn-wisdom').style.display = 'inline-block';
    }, 2000);
}

/**
 * 智能解读生成 - 三张牌阵专业解读
 * 第一张：当前状态 | 第二张：隐藏因素 | 第三张：未来趋势
 */
function generateSmartInterpretation() {
    const [card1, card2, card3] = state.cards;
    const meanings1 = cardDeepMeanings[card1.name];
    const meanings2 = cardDeepMeanings[card2.name];
    const meanings3 = cardDeepMeanings[card3.name];
    
    // 随机选择模板
    const opening = spreadTemplates.opening[Math.floor(Math.random() * spreadTemplates.opening.length)];
    const present = spreadTemplates.present[Math.floor(Math.random() * spreadTemplates.present.length)];
    const hidden = spreadTemplates.hidden[Math.floor(Math.random() * spreadTemplates.hidden.length)];
    const future = spreadTemplates.future[Math.floor(Math.random() * spreadTemplates.future.length)];
    const closing = spreadTemplates.closing[Math.floor(Math.random() * spreadTemplates.closing.length)];
    
    // 构建卡片名称
    const cards = [card1, card2, card3].map(c => c.nameCN).join('、');
    
    // 填充模板
    let interpretation = opening
        .replace('{cards}', cards)
        .replace('{card1.name}', card1.nameCN)
        .replace('{card2.name}', card2.nameCN)
        .replace('{card3.name}', card3.nameCN);
    
    interpretation += '\n\n【现状之境】\n' + present
        .replace(/{card1.name}/g, card1.nameCN)
        .replace(/{card1.keyword}/g, meanings1.keyword)
        .replace(/{card1.meaning}/g, meanings1.present)
        .replace(/{card1.quality}/g, getCardQuality(card1));
    
    interpretation += '\n\n【隐匿之影】\n' + hidden
        .replace(/{card2.name}/g, card2.nameCN)
        .replace(/{card2.keyword}/g, meanings2.keyword)
        .replace(/{card2.meaning}/g, meanings2.hidden);
    
    interpretation += '\n\n【未来之流】\n' + future
        .replace(/{card3.name}/g, card3.nameCN)
        .replace(/{card3.keyword}/g, meanings3.keyword)
        .replace(/{card3.meaning}/g, meanings3.future);
    
    interpretation += '\n\n' + closing
        .replace(/{cards}/g, cards)
        .replace(/{card1.name}/g, card1.nameCN)
        .replace(/{card2.name}/g, card2.nameCN)
        .replace(/{card3.name}/g, card3.nameCN);
    
    return interpretation;
}

/**
 * 获取卡牌的品质描述
 */
function getCardQuality(card) {
    const positiveCards = ['The Sun', 'The Star', 'The World', 'The Magician', 'The Empress', 'The Fool', 'Strength', 'Temperance'];
    const challengingCards = ['The Moon', 'The Tower', 'The Devil', 'Death', 'The Hanged Man'];
    
    if (positiveCards.includes(card.name)) return '积极而充满可能性';
    if (challengingCards.includes(card.name)) return '具有挑战性但蕴含成长';
    return '中性而平衡';
}

/**
 * 生成关系占卜解读 - 关于两个人的连结
 * 第一张：你的位置 | 第二张：关系动态 | 第三张：潜在可能
 */
function generateRelationshipInterpretation() {
    // 生成随机编号 (1000-9999)
    const answerId = Math.floor(1000 + Math.random() * 9000);
    document.querySelector('#relation-answer-id span').textContent = answerId;
    
    document.getElementById('display-person-name').textContent = state.personName;

    state.cards.forEach((card, index) => {
        const miniCard = document.getElementById(`relation-mini-card-${index + 1}`);
        const labels = ['你', '之间', '可能'];
        miniCard.innerHTML = `
            <div style="font-size:0.6rem;color:rgba(157,123,255,0.8);margin-bottom:2px;">${labels[index]}</div>
            <div style="font-size:0.7rem;font-weight:bold;">${card.nameCN}</div>
            <div style="font-size:0.5rem;margin-top:2px;opacity:0.7;">${card.keywords[0]}</div>
        `;
    });

    document.getElementById('relation-interpret-loading').style.display = 'block';
    document.getElementById('relation-interpret-content').style.display = 'none';
    document.getElementById('btn-relation-wisdom').style.display = 'none';

    setTimeout(() => {
        const interpretation = generateRelationshipSpread();

        state.interpretation = interpretation;

        document.getElementById('relation-interpret-text').textContent = state.interpretation;
        document.getElementById('relation-interpret-loading').style.display = 'none';
        document.getElementById('relation-interpret-content').style.display = 'block';
        document.getElementById('btn-relation-wisdom').style.display = 'inline-block';
    }, 2000);
}

/**
 * 生成关系牌阵解读
 */
function generateRelationshipSpread() {
    const [card1, card2, card3] = state.cards;
    const meanings1 = cardRelationshipMeanings[card1.name];
    const meanings2 = cardRelationshipMeanings[card2.name];
    const meanings3 = cardRelationshipMeanings[card3.name];

    // 随机选择模板
    const opening = relationshipSpread.opening[Math.floor(Math.random() * relationshipSpread.opening.length)];
    const yourPosition = relationshipSpread.yourPosition[Math.floor(Math.random() * relationshipSpread.yourPosition.length)];
    const dynamics = relationshipSpread.dynamics[Math.floor(Math.random() * relationshipSpread.dynamics.length)];
    const potential = relationshipSpread.potential[Math.floor(Math.random() * relationshipSpread.potential.length)];
    const closing = relationshipSpread.closing[Math.floor(Math.random() * relationshipSpread.closing.length)];

    // 构建卡片名称
    const cards = [card1, card2, card3].map(c => c.nameCN).join('、');

    // 填充模板
    let interpretation = opening
        .replace(/{cards}/g, cards)
        .replace(/{name}/g, state.personName)
        .replace(/{card1.name}/g, card1.nameCN)
        .replace(/{card2.name}/g, card2.nameCN)
        .replace(/{card3.name}/g, card3.nameCN);

    interpretation += '\n\n【你在此刻】\n' + yourPosition
        .replace(/{card1.name}/g, card1.nameCN)
        .replace(/{card1.keyword}/g, card1.keywords[0])
        .replace(/{card1.relationshipYou}/g, meanings1.relationshipYou)
        .replace(/{name}/g, state.personName);

    interpretation += '\n\n【之间流动】\n' + dynamics
        .replace(/{card2.name}/g, card2.nameCN)
        .replace(/{card2.keyword}/g, card2.keywords[0])
        .replace(/{card2.relationshipDynamic}/g, meanings2.relationshipDynamic)
        .replace(/{name}/g, state.personName);

    interpretation += '\n\n【潜在可能】\n' + potential
        .replace(/{card3.name}/g, card3.nameCN)
        .replace(/{card3.keyword}/g, card3.keywords[0])
        .replace(/{card3.relationshipPotential}/g, meanings3.relationshipPotential)
        .replace(/{name}/g, state.personName);

    interpretation += '\n\n' + closing
        .replace(/{cards}/g, cards)
        .replace(/{name}/g, state.personName)
        .replace(/{card1.name}/g, card1.nameCN)
        .replace(/{card2.name}/g, card2.nameCN)
        .replace(/{card3.name}/g, card3.nameCN);

    return interpretation;
}

/**
 * 生成宇宙格言 - 优先使用爆款传播格言
 */
function generateWisdom() {
    document.getElementById('wisdom-loading').style.display = 'block';
    document.getElementById('wisdom-content').style.display = 'none';
    document.getElementById('btn-share').style.display = 'none';
    
    setTimeout(() => {
        // 70%概率使用爆款格言（适合传播），30%概率使用主题格言
        let quotes;
        if (Math.random() < 0.7) {
            quotes = wisdomQuotes.viral;
        } else {
            // 根据牌面类型选择格言主题
            const readingType = getReadingType(state.cards);
            let theme = 'inner';
            if (readingType === 'positive') theme = 'hope';
            else if (readingType === 'challenging') theme = 'change';
            else if (readingType === 'transformative') theme = 'timing';
            quotes = wisdomQuotes[theme];
        }
        
        const wisdom = quotes[Math.floor(Math.random() * quotes.length)];
        state.wisdom = wisdom;
        
        document.getElementById('wisdom-text').textContent = wisdom;
        document.getElementById('wisdom-loading').style.display = 'none';
        document.getElementById('wisdom-content').style.display = 'block';
        document.getElementById('btn-share').style.display = 'inline-block';
    }, 1500);
}

// 简短总结库 - 用于分享卡片
const shortSummaries = {
    'The Fool': '新的旅程即将开启，保持初心与勇气',
    'The Magician': '你拥有实现愿望的所有资源',
    'The High Priestess': '答案在你的内心深处，倾听直觉',
    'The Empress': '丰盛的能量正在流向你',
    'The Emperor': '建立稳固的基础，保持理性',
    'The Lovers': '一个重要的选择或关系浮现',
    'The Chariot': '通过意志力克服困难，勇往直前',
    'Strength': '真正的力量来自内在的平静',
    'The Hermit': '需要独处反思，寻找内在的光',
    'Wheel of Fortune': '变化正在发生，顺应时机',
    'Justice': '因果法则运作，保持诚实',
    'The Hanged Man': '换个角度看问题，放下控制',
    'Death': '旧的周期结束，新生即将开始',
    'Temperance': '寻找平衡与和谐之道',
    'The Devil': '看见束缚，你有力量解开锁链',
    'The Tower': '突然的变化带来觉醒',
    'The Star': '希望之光照亮前路',
    'The Moon': '穿越迷雾，跟随直觉',
    'The Sun': '光明和成功的能量充满你',
    'Judgement': '觉醒的时刻，回应内心的召唤',
    'The World': '一个完整的周期即将圆满完成'
};

/**
 * 生成简短总结
 */
function generateShortSummary() {
    const [card1, card2, card3] = state.cards;
    const summary1 = shortSummaries[card1.name];
    const summary2 = shortSummaries[card2.name];
    const summary3 = shortSummaries[card3.name];
    
    if (state.mode === 'relationship') {
        return `【${card1.nameCN}】${summary1}\n【${card2.nameCN}】${summary2}\n【${card3.nameCN}】${summary3}`;
    } else {
        return `【现状】${summary1}\n【隐藏】${summary2}\n【趋势】${summary3}`;
    }
}

/**
 * 准备分享卡片
 */
function prepareShareCard() {
    if (state.mode === 'relationship') {
        document.getElementById('share-question').textContent = '关于 ' + state.personName + ' 的这段关系';
    } else {
        document.getElementById('share-question').textContent = state.question;
    }
    // 使用简短总结代替长解读
    document.getElementById('share-interpret').textContent = generateShortSummary();
    document.getElementById('share-wisdom').textContent = state.wisdom;
}

/**
 * 下载分享卡片
 */
function downloadCard() {
    const cardElement = document.getElementById('share-card');
    
    html2canvas(cardElement, {
        backgroundColor: '#0a0a1a',
        scale: 2
    }).then(canvas => {
        const link = document.createElement('a');
        link.download = `宇宙回复-${Date.now()}.png`;
        link.href = canvas.toDataURL();
        link.click();
    }).catch(err => {
        console.error('生成图片失败:', err);
        alert('图片生成失败，请重试');
    });
}

// 初始化首页每日格言 - 基于日期，每天显示同一句
function initDailyQuote() {
    const quoteText = document.getElementById('daily-wisdom-text');
    if (quoteText) {
        // 使用今天的日期作为随机种子，确保同一天显示相同的格言
        const today = new Date();
        const dateSeed = today.getFullYear() * 10000 + (today.getMonth() + 1) * 100 + today.getDate();
        
        // 简单的伪随机数生成
        const randomIndex = dateSeed % dailyWisdomQuotes.length;
        quoteText.innerHTML = dailyWisdomQuotes[randomIndex].replace(/\n/g, '<br>');
    }
}

// 初始化
document.addEventListener('DOMContentLoaded', function() {
    console.log('✨ 宇宙正在回复你 - 已加载');
    initDailyQuote();
});
